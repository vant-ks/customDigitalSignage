# VANT Signage Agent — systemd unit file
# Install: cp vant-agent.service /etc/systemd/system/
#          systemctl daemon-reload
#          systemctl enable vant-agent
#          systemctl start vant-agent

[Unit]
Description=VANT Signage Display Agent
After=network-online.target graphical-session.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi
Environment=VANT_CONFIG=/etc/vant-agent/config.yaml
Environment=DISPLAY=:0

# Start the agent
ExecStart=/usr/local/bin/vant-agent run

# Restart on failure with backoff
Restart=on-failure
RestartSec=10
StartLimitInterval=60
StartLimitBurst=5

# Output to journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vant-agent

[Install]
WantedBy=multi-user.target
